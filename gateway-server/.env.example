# Gateway Server configurations
# For local hardware deployment: DB_HOST points to local MySQL running the 'smsd' database
# For cloud deployment: DB_HOST points to local MySQL running 'smsd' next to the physical modem
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=upbs2024
DB_PASSWORD=upbs2024
DB_NAME=smsd
DB_SSL=false

# Worker API connection
# Set this to http://localhost:3001 if worker-api runs locally.
# Set this to the cloud URL (e.g. https://your-cloud-worker.com) if worker-api runs in the cloud.
WORKER_URL=http://localhost:3001

# Shared secret key and API token to authenticate calls between gateway-server and worker-api
GATEWAY_SECRET=upbs-modem-sec-key-1837
GATEWAY_API_KEY=upbs-gateway-secret-api-key-2026
